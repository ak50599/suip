{
    "name": "suip/university-portal",
    "description": "Student University Information Portal - نظام إدارة الجامعة",
    "type": "project",
    "license": "MIT",
    "authors": [
        {
            "name": "M.Hamza AlNawaf",
            "email": "admin@suip.edu"
        }
    ],
    "require": {
        "php": ">=8.0",
        "ext-pdo": "*",
        "ext-mysqli": "*",
        "ext-json": "*",
        "ext-mbstring": "*"
    },
    "require-dev": {
        "phpunit/phpunit": "^9.6",
        "phpstan/phpstan": "^1.10",
        "squizlabs/php_codesniffer": "^3.7"
    },
    "autoload": {
        "psr-4": {
            "SUIP\\": "src/"
        },
        "files": [
            "includes/functions.php"
        ]
    },
    "autoload-dev": {
        "psr-4": {
            "SUIP\\Tests\\": "tests/"
        }
    },
    "scripts": {
        "test": "phpunit",
        "test:unit": "phpunit --testsuite Unit",
        "test:integration": "phpunit --testsuite Integration",
        "analyse": "phpstan analyse src includes --level=5",
        "lint": "phpcs --standard=PSR12 src includes",
        "lint:fix": "phpcbf --standard=PSR12 src includes"
    },
    "config": {
        "optimize-autoloader": true,
        "preferred-install": "dist",
        "sort-packages": true
    }
}
